# ==========================================
# 🔐 SAVIA — Variables d'environnement
# ==========================================
# Copiez ce fichier en .env et remplissez les valeurs
#   cp .env.example .env
#   nano .env

# ── PostgreSQL ────────────────────────────
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── MinIO (Object Storage S3-compatible) ──
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── Backend (FastAPI) ─────────────────────
JWT_SECRET=
PORT=8000

# ── Base de données (auto-construit si vide) ──
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ── S3 / MinIO (utilisé par le backend) ───
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# ── Google Gemini AI ──────────────────────
# Clé API unique
GOOGLE_API_KEY=
# Multi-clés pour rotation automatique (séparées par virgules)
GOOGLE_API_KEYS=

# ── Sécurité ──────────────────────────────
# Clé Fernet pour chiffrement de licence
MASTER_KEY=
# Code d'accès distant
ACCESS_CODE=

# ── Telegram (notifications) ─────────────
# Configuré via l'interface admin SAVIA
# (stocké en base de données, pas ici)

# ── Frontend ──────────────────────────────
NEXT_PUBLIC_API_URL=
BACKEND_URL=
