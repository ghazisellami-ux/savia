# Variables d'environnement pour SIC - Maintenance Prédictive
# Copiez ce fichier en .env et remplissez les valeurs

# Clé API Google Gemini (simple)
GOOGLE_API_KEY=votre_cle_api_ici

# Multi-clés pour rotation automatique (séparées par des virgules)
# Quand une clé atteint son quota, le système passe automatiquement à la suivante
GOOGLE_API_KEYS=cle1,cle2,cle3

# Clé maitre pour le chiffrement de licence (Fernet)
MASTER_KEY=EjoEM28PNJHXPBRgb1bXgZTZp_HGWS8wgjSxcuu6AfE=


# Code d'accès distant (pour utilisateurs à distance)
ACCESS_CODE=SIC2026

# ==========================================
# BASE DE DONNÉES (Configuration Serveur)
# ==========================================

# URL de connexion PostgreSQL (Décommentez et remplissez pour la production)
# Format : postgres://utilisateur:mot_de_passe@adresse_serveur:port/nom_base
DATABASE_URL=postgres://votre_user:votre_mot_de_passe@localhost:5432/sic_radiologie
