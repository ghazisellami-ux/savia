# ============================================
# SAVIA — .gitignore (Production Clean)
# ============================================

# ---- Sécurité & Configuration locale ----
.env
.env.*
!.env.example

# ---- Base de données ----
*.db
*.db-journal
*.db-wal
*.sqlite3

# ---- Fichiers sensibles ----
pgpass
pgadmin_servers.json
*.key

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ---- Environnement virtuel ----
venv/
env/
.venv/

# ---- Logs ----
logs/
*.log

# ---- Backups & données générées ----
backups/
backup_complet.json
data/

# ---- Rapports générés ----
reports/

# ---- Fichiers binaires ----
*.zip
*.pptx

# ---- IDE & Outils ----
.qodo/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Docker (runtime) ----
docker-compose.override.yml

# ---- Node.js ----
node_modules/
.next/
